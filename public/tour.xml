	<!-- ============================================== -->
	<!-- 全局自动巡游动画控制 (用户操作前持续跨场景轮播) -->
	<!-- ============================================== -->
	
	<events name="intro_events" keep="true"
	        onnewscene="js(onPanoSceneChanged(get(xml.scene))); start_global_autotour();"
	        onmousedown="cancel_intro();"
	        ontouchstart="cancel_intro();"
	        onmousewheel="cancel_intro();"
	        onkeydown="cancel_intro();"
	        />

	<action name="init_intro_state" autorun="preinit">
		set(global_intro_cancelled, false);
	</action>

	<action name="start_global_autotour">
		if(!global_intro_cancelled,
			set(is_intro_running, true);
			
			<!-- 计算下一个场景的索引，如果到最后一个则回到第一个 -->
			copy(cur_idx, scene[get(xml.scene)].index);
			add(next_idx, cur_idx, 1);
			if(next_idx == scene.count, set(next_idx, 0));
			copy(next_scene_name, scene[get(next_idx)].name);
			
			<!-- 自动旋转 270 度，耗时 20 秒，完成后切换到下一个场景 -->
			tween(view.hlookat, calc(view.hlookat + 270), 20, linear,
				if(is_intro_running,
					set(is_intro_running, false);
					loadscene(get(next_scene_name), null, MERGE, BLEND(1.5, easeInCubic));
				);
			);
		);
	</action>

	<action name="cancel_intro">
		if(!global_intro_cancelled,
			set(global_intro_cancelled, true);
			set(is_intro_running, false);
			stoptween(view.hlookat);
		);
	</action>
